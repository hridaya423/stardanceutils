{
    "manifest_version": 3,
    "name": "Stardance Utils",
    "version": "0.0.3",
    "description": "A utility extension for Stardance, with multiple useful features to enhance the experience",
    "permissions": [
        "storage"
    ],
    "icons": {
        "32": "icon32.png",
        "64": "icon64.png",
        "128": "icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://stardance.hackclub.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
